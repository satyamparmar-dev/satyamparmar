{
  "name": "satyverse-satyam-parmar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "enrich:theory": "node scripts/run-theory-enrichment.mjs",
    "build:allowlist": "node scripts/encrypt-allowlist.mjs",
    "build:interview-themes": "node scripts/build-interview-themes.mjs",
    "split:phase-data": "node scripts/split-all-phase-data.mjs",
    "preview": "npm run build && wrangler dev",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "deploy": "npm run build && wrangler deploy",
    "validate:days": "node scripts/validate-day-files.mjs",
    "backfill:followups": "node scripts/backfill-interview-followups.mjs",
    "gen:phase6": "node scripts/gen-phase6/build.mjs",
    "gen:phase7": "node scripts/gen-phase7/build.mjs",
    "gen:phase8910": "node scripts/gen-phase8910/build.mjs",
    "gen:phase2-mcq": "node scripts/gen-phase2-mcq.mjs && node scripts/inject-phase2-mcq.mjs",
    "gen:phase3-days": "node scripts/phase3/emit.mjs && node scripts/phase3/validate-phase3.mjs",
    "gen:phase4-days": "node scripts/phase4/emit.mjs && node scripts/phase4/validate-phase4.mjs",
    "gen:phase5-days": "node scripts/phase5/emit.mjs && node scripts/phase5/validate-phase5.mjs",
    "gen:phase6-days": "node scripts/phase6/emit.mjs && node scripts/phase6/validate-phase6.mjs",
    "gen:phase7-days": "node scripts/phase7/emit.mjs && node scripts/phase7/validate-phase7.mjs"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.15",
    "@mui/material": "^5.15.15",
    "axios": "^1.6.8",
    "date-fns": "^3.6.0",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.9.0",
    "marked": "^12.0.0",
    "pako": "^2.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.51.3",
    "react-router-dom": "^6.23.1",
    "recharts": "^2.12.7",
    "zod": "^3.23.6",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^6.0.0",
    "@types/pako": "^2.0.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.6",
    "typescript": "^5.4.5",
    "vite": "^6.4.1",
    "wrangler": "^4.80.0"
  }
}
