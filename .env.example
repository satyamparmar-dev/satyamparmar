# Copy to .env and fill in values before running locally
# NEVER commit .env to git
VITE_APP_SECRET=your-random-secret-min-32-chars
VITE_ALLOWLIST_CRYPTO_SECRET=your-allowlist-secret-then-run-npm-run-build-allowlist
# For GitHub Pages (satyamparmar.blog), set the same values as repo Secrets:
# VITE_STORAGE_SECRET=your-storage-secret-min-32-chars
# Copy protection is ON by default. To allow copy during local dev, uncomment one of:
# VITE_DISABLE_CONTENT_PROTECTION=true
# VITE_DISABLE_CONTENT_PROTECTION=1
# VITE_DISABLE_CONTENT_PROTECTION=yes
