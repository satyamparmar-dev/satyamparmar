@startuml Kafka Architecture
!theme plain
skinparam backgroundColor #FFFFFF
skinparam componentStyle rectangle

title Kafka Cluster Architecture

package "Kafka Cluster" {
    component "Broker 1" as broker1
    component "Broker 2" as broker2
    component "Broker 3" as broker3
}

package "Topics" {
    component "Topic: user-events" as topic {
        component "Partition 0" as p0
        component "Partition 1" as p1
        component "Partition 2" as p2
    }
}

package "Producers" {
    component "Producer 1" as prod1
    component "Producer 2" as prod2
}

package "Consumers" {
    component "Consumer Group A" as cgA {
        component "Consumer 1" as c1
        component "Consumer 2" as c2
    }
    component "Consumer Group B" as cgB {
        component "Consumer 3" as c3
    }
}

component "Zookeeper" as zk

' Connections
prod1 --> p0 : Write
prod1 --> p1 : Write
prod2 --> p2 : Write

p0 --> c1 : Read
p1 --> c2 : Read
p2 --> c1 : Read

p0 --> c3 : Read (different group)

broker1 --> zk : Coordination
broker2 --> zk : Coordination
broker3 --> zk : Coordination

note right of topic
  **Topic Structure:**
  - Partition 0: Leader on Broker 1
  - Partition 1: Leader on Broker 2
  - Partition 2: Leader on Broker 3
  - Replication Factor: 3
end note

note right of cgA
  **Consumer Group A:**
  - 2 consumers
  - 3 partitions
  - Consumer 1 reads from P0 and P2
  - Consumer 2 reads from P1
end note

@enduml
