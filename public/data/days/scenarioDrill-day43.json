{
  "day": 43,
  "title": "Spring Boot Config & Actuator",
  "phaseId": "phase5",
  "tags": [
    "properties",
    "profiles",
    "actuator security"
  ],
  "scenarios": [
    {
      "id": "d43-s1",
      "question": "Actuator endpoints exposed publicly—risk and fix?",
      "signals": [
        "security",
        "management.server.port",
        "Spring Security"
      ],
      "answer": "**Sensitive** data (`env`, `heapdump`)—**lock down** with **Security**, **separate management port**, **network** ACLs, **disable** in prod if unused.",
      "followUps": [
        {
          "question": "Config precedence?",
          "answer": "Command line > OS env > **application-{profile}.yml** > defaults—document for team."
        }
      ]
    },
    {
      "id": "d43-s2",
      "question": "`@ConfigurationProperties` vs `@Value`?",
      "signals": [
        "type-safe",
        "validation"
      ],
      "answer": "**`ConfigurationProperties`** for **structured** config with **validation** (`@Validated`)—**`@Value`** for **simple** scalars.",
      "followUps": [
        {
          "question": "Relaxed binding?",
          "answer": "`my.service-url` maps to **`serviceUrl`**—helps **env var** conventions."
        }
      ]
    },
    {
      "id": "d43-s3",
      "question": "Health check shows UP but app cannot reach DB—improve?",
      "signals": [
        "liveness",
        "readiness",
        "custom HealthIndicator"
      ],
      "answer": "Separate **liveness** vs **readiness**—custom **`HealthIndicator`** for **dependencies**; K8s **probes** aligned.",
      "followUps": [
        {
          "question": "Metrics export cardinality?",
          "answer": "Avoid **high-cardinality** tags (user id)—**blows** TSDB—**aggregate**."
        }
      ]
    }
  ]
}
