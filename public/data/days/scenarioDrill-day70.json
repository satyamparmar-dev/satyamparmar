{
  "day": 70,
  "title": "NoSQL - MongoDB & Cassandra",
  "phaseId": "phase8",
  "tags": [
    "document",
    "partition key",
    "CQL"
  ],
  "scenarios": [
    {
      "id": "d70-s1",
      "question": "MongoDB aggregation slow—directions?",
      "signals": [
        "index",
        "allowDiskUse",
        "shard key"
      ],
      "answer": "**Index** supports **match/sort**, **`explain`** stages, **avoid** huge **`$lookup`** without indexes, **shard key** causes **hot shard**—**scatter-gather** cost.",
      "followUps": [
        {
          "question": "Cassandra partition too wide?",
          "answer": "**Billions** rows per partition **bad**—**unbounded** growth—**repartition** model."
        }
      ]
    },
    {
      "id": "d70-s2",
      "question": "Cassandra consistency `LOCAL_QUORUM` vs `ONE`?",
      "signals": [
        "latency",
        "tunable"
      ],
      "answer": "**ONE** faster **possible stale**; **LOCAL_QUORUM** **stronger** within **datacenter**—**tie** to **SLA** and **replication**.",
      "followUps": [
        {
          "question": "Mongo transaction across shards?",
          "answer": "**Supported** with **cost**—prefer **single-shard** **document** design when possible."
        }
      ]
    },
    {
      "id": "d70-s3",
      "question": "When not to use Mongo for financial ledger?",
      "signals": [
        "ACID",
        "constraints",
        "reporting"
      ],
      "answer": "Need **strong relational constraints**, **complex joins**, **ledger** invariants—**relational** often clearer—**polyglot** persistence acceptable.",
      "followUps": [
        {
          "question": "BSON size limit?",
          "answer": "**16MB** document—**grid** large blobs—design **chunking**."
        }
      ]
    }
  ]
}
